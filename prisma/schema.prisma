generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model PoliticalProfile {
  id             String   @id @default(cuid())
  name           String
  role           String
  city           String
  party          String?
  instagram      String
  mainAudience   String
  mainThemes     String
  desiredTone    String
  languageRules  String
  avoidWords     String
  useWords       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  scripts        Script[]
  analyses       InstagramAnalysis[]
  assemblyStrategies AssemblyStrategy[]
}

model InstagramAnalysis {
  id                   String   @id @default(cuid())
  profileId            String?
  profileUrl           String
  username             String
  publicName           String
  bioSummary           String
  detectedTone         String
  frequentThemes       String
  probableAudience     String
  strengths            String
  weaknesses           String
  contentOpportunities String
  reelIdeas            String
  speechIdeas          String
  communicationRisks   String
  captionSuggestions   String
  hashtagSuggestions   String
  rawAnalysis          String
  status               String   @default("pronto")
  city                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  profile              PoliticalProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scripts              Script[]
  assemblyStrategies   AssemblyStrategy[]
}

model Script {
  id              String   @id @default(cuid())
  profileId       String?
  instagramAnalysisId String?
  profileName     String?
  instagramUsername String?
  title           String
  type            String
  duration        String
  style           String
  theme           String
  format          String   @default("gancho_forte")
  hook            String   @default("")
  fullScript      String   @default("")
  pauseMarks      String   @default("")
  cameraDir       String   @default("")
  sceneSuggestion String   @default("")
  captionSuggestion String @default("")
  ctaSuggestion   String   @default("")
  hashtags        String   @default("")
  shortVersion    String   @default("")
  emotionalVersion String @default("")
  institutionalVersion String @default("")
  isPublic        Boolean  @default(false)
  estimatedWords  Int?
  objective       String?
  scriptText      String?
  captionText     String?
  cta             String?
  scenarioSuggestion String?
  framingSuggestion  String?
  strategicNotes  String?
  administrativeRegionId String?
  savedTerritoryId String?
  territoryAnalysisId String?
  territoryName String?
  territoryContext String?
  territorialObjectives String?
  territorialNarrative String?
  territoryFactsToVerify String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profile         PoliticalProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  analysis        InstagramAnalysis? @relation(fields: [instagramAnalysisId], references: [id], onDelete: SetNull)
  reelCards       ReelCard[]
  assemblyStrategies AssemblyStrategy[]
}

model ReelCard {
  id          String   @id @default(cuid())
  scriptId    String?
  title       String
  theme       String
  duration    String
  status      String   @default("ideia")
  suggestedDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  script      Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)
}

model StylePreset {
  id          String   @id @default(cuid())
  name        String
  description String
  tone        String
  tips        String
  example     String
  createdAt   DateTime @default(now())
}

model EditorialCalendarItem {
  id                     String   @id @default(cuid())
  profileId              String?
  scriptId               String?
  assemblyStrategyId     String?
  administrativeRegionId String?
  savedTerritoryId       String?
  territoryAnalysisId    String?

  // Scheduling
  scheduledDate          String?
  scheduledTime          String?
  month                  Int?
  week                   Int?
  day                    Int?
  hour                   Int?
  minute                 Int?
  dayOfWeek              Int

  // Content
  label                  String
  description            String
  contentType            String   @default("reels")
  territoryName          String?

  // Workflow
  status                 String   @default("ideia")

  // Visual
  color                  String
  priority               String   @default("media")

  // Metadata
  thumbnail              String?
  notes                  String?
  responsible            String?
  checklist              String?

  // Timestamps
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AssemblyStrategy {
  id             String   @id @default(cuid())
  profileId      String?
  instagramAnalysisId String?
  scriptId       String?
  administrativeRegionId String?
  savedTerritoryId String?
  territoryAnalysisId String?
  recordingReferencePoint String?
  alternativeLocation String?
  title          String
  videoType      String   @default("solo")
  objective      String   @default("")
  centralMessage String   @default("")
  visualHook     String   @default("")
  firstLine      String   @default("")
  recordingLocation String @default("")
  recordingAddress String  @default("")
  recordingDate  String?
  recordingTime  String?
  postingDate    String?
  postingTime    String?
  status         String   @default("rascunho")
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  canvasItems    AssemblyCanvasItem[]
  participants   AssemblyParticipant[]
  interviewees   AssemblyInterviewee[]
  profile        PoliticalProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  analysis       InstagramAnalysis? @relation(fields: [instagramAnalysisId], references: [id], onDelete: SetNull)
  script         Script? @relation(fields: [scriptId], references: [id], onDelete: SetNull)
}

model AssemblyCanvasItem {
  id         String   @id @default(cuid())
  strategyId String
  type       String
  title      String   @default("")
  content    String   @default("")
  x          Float    @default(0)
  y          Float    @default(0)
  width      Float    @default(200)
  height     Float    @default(100)
  position   Int      @default(0)
  color      String   @default("")
  metadata   String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  strategy   AssemblyStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model AssemblyParticipant {
  id             String   @id @default(cuid())
  strategyId     String
  name           String
  role           String   @default("")
  phone          String   @default("")
  instagram      String   @default("")
  responsibility String   @default("")
  status         String   @default("pendente")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  strategy       AssemblyStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model AssemblyInterviewee {
  id                     String   @id @default(cuid())
  strategyId             String
  name                   String
  profile                String   @default("")
  speechTheme            String   @default("")
  mainQuestion           String   @default("")
  supportQuestions       String   @default("")
  imageAuthorizationStatus String @default("pendente")
  status                 String   @default("pendente")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  strategy               AssemblyStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model AdministrativeRegion {
  id                String   @id @default(cuid())
  officialNumber    Int      @unique
  romanNumber       String
  officialName      String
  slug              String   @unique
  aliases           String?
  stateCode         String   @default("DF")
  countryCode       String   @default("BR")
  divisionType      String   @default("ADMINISTRATIVE_REGION")
  status            String   @default("ACTIVE")
  officialSourceName String?
  officialSourceUrl  String?
  effectiveDate     DateTime?
  latitude          Float?
  longitude         Float?
  geoJson           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  localities        TerritoryLocality[]
  territories       SavedTerritory[]
  analyses          TerritoryAnalysis[]
  publicData        TerritoryPublicData[]
  equipments        TerritoryEquipment[]
}

model TerritoryLocality {
  id                     String @id @default(cuid())
  administrativeRegionId String
  name                   String
  slug                   String
  type                   String
  aliases                String?
  status                 String @default("ACTIVE")
  latitude               Float?
  longitude              Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  administrativeRegion   AdministrativeRegion @relation(fields: [administrativeRegionId], references: [id])
  @@unique([administrativeRegionId, slug])
}

model SavedTerritory {
  id                     String @id @default(cuid())
  profileId              String
  instagramAnalysisId    String?
  administrativeRegionId String
  localityId             String?
  customLocalityName     String?
  sector                 String?
  block                  String?
  referencePoint         String?
  approximateAddress     String?
  locationType           String?
  title                  String
  description            String?
  status                 String @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  administrativeRegion   AdministrativeRegion @relation(fields: [administrativeRegionId], references: [id])
  analyses               TerritoryAnalysis[]
}

model TerritoryAnalysis {
  id                     String @id @default(cuid())
  profileId              String
  instagramAnalysisId    String?
  savedTerritoryId       String?
  administrativeRegionId String
  localityId             String?
  scriptId               String?
  contextText            String
  contextVersion         Int @default(1)
  territorialObjectives  String?
  analysisDepth          String
  sourceType             String
  referenceDate          DateTime?
  territorySummary       String?
  contextSummary         String?
  mainTheme              String?
  secondaryThemes        String?
  centralSituation       String?
  identifiedProblems     String?
  opportunities          String?
  involvedActors         String?
  mentionedInstitutions  String?
  relatedPublic          String?
  localSensitivities     String?
  recommendedVocabulary  String?
  termsToAvoid           String?
  narrativeAngle         String?
  suggestedHook          String?
  centralMessage         String?
  recommendedApproach    String?
  scenarioSuggestion     String?
  recordingPoints        String?
  confirmedFacts         String?
  userProvidedFacts      String?
  aiInferences           String?
  factsToVerify          String?
  generalizationRisks    String?
  communicationRisks     String?
  shortNarrative         String?
  sourcesUsed            String?
  confidence             Float?
  status                 String @default("WAITING")
  analyzedAt             DateTime?
  expiresAt              DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  administrativeRegion   AdministrativeRegion @relation(fields: [administrativeRegionId], references: [id])
  savedTerritory         SavedTerritory? @relation(fields: [savedTerritoryId], references: [id])
}

model TerritoryPublicData {
  id                     String @id @default(cuid())
  administrativeRegionId String
  category               String
  indicatorName          String
  valueText              String?
  numericValue           Float?
  unit                   String?
  referenceDate          DateTime
  sourceName             String
  sourceUrl              String
  verificationStatus     String @default("PENDING")
  collectedAt            DateTime @default(now())
  expiresAt              DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  administrativeRegion   AdministrativeRegion @relation(fields: [administrativeRegionId], references: [id])
}

model TerritoryEquipment {
  id                     String @id @default(cuid())
  administrativeRegionId String
  localityId             String?
  name                   String
  type                   String
  address                String?
  referencePoint         String?
  latitude               Float?
  longitude              Float?
  sourceName             String?
  sourceUrl              String?
  verificationStatus     String @default("PENDING")
  isActive               Boolean @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  administrativeRegion   AdministrativeRegion @relation(fields: [administrativeRegionId], references: [id])
}
